    "nexla:bootstrap": "bun scripts/nexla-bootstrap.ts"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.4",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.19",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
